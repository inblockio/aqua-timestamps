[server]
listen = "0.0.0.0:8080"

[identity]
# Chain id used inside the published `did:pkh` (1 = Ethereum mainnet,
# mirrors aquafire's pattern). The actual anchor chain is a separate
# concern, configured in M4.
chain_id     = 1
trust_domain = "timestamp"
dns          = "timestamp.inblock.io"
ip           = "139.59.144.60"

[auth]
challenge_ttl_secs = 300
session_ttl_secs   = 3600
# Empty list = accept any authenticated DID at M1.
allowed_dids = [
  # "did:pkh:eip155:1:0x0000000000000000000000000000000000000000",
]

[storage]
# Directory the fjall keyspace lives in. Created on first start. In Docker
# this is the named volume mounted from `deploy/docker-compose.yml`.
path = "/var/lib/aqua-timestamp/state"

[epoch]
# Wall-clock duration of one accumulation window before the seal task
# fires. 600s (10 min) matches the design-spec target. Lower values are
# useful when running locally against a faucet.
duration_secs = 600
# Hard cap on the leaves array in a single `POST /v1/leaves`. Requests
# above this are rejected with 400.
max_leaves_per_request = 10000

[anchors.evm]
# Live anchoring toggle. `true` constructs an `aqua-rs-sdk`
# `CliEthTimestamper` at boot and submits one `witness(bytes32)` tx per
# non-empty epoch, signed by the service mnemonic. `false` keeps the M3
# stub behaviour (witnesses minted with zero `transaction_hash`).
enabled       = true
# JSON-RPC URL of the chain to anchor on. Public free endpoints are fine
# for M4; production should switch to a paid endpoint at M6.
rpc_url       = "https://ethereum-sepolia-rpc.publicnode.com"
# One of `mainnet`, `sepolia`, `holesky`, or `custom:<chain_id>`.
chain         = "sepolia"
# `network` field embedded in the EVM witness payload. Usually matches
# `chain`. Kept separate so `custom:<id>` setups can still surface a
# human-readable name in witnesses.
network_label = "sepolia"

[anchors.qtsa]
# Live qTSA toggle. `true` constructs an `aqua-rs-sdk`
# `TsaTimestamper` at boot and submits one RFC 3161 request per
# non-empty epoch. `false` mints stub qTSA witnesses
# (`transaction_hash = 0x...000`, `tsa_provider = "stub"`).
enabled                  = true
# RFC 3161 TSA endpoint. Examples:
#   eIDAS-qualified : http://timestamp.sectigo.com/qualified
#                     http://timestamp.dtrust.de
#                     http://qts.identrust.com
#   free standard   : http://timestamp.digicert.com
#                     http://timestamp.sectigo.com
url                      = "http://timestamp.sectigo.com/qualified"
# Minimum spacing between requests. Sectigo's qualified endpoint asks
# for 16s. Set to 0 for free standard TSAs (no throttle).
min_request_interval_secs = 16
# `network` field embedded in the qTSA witness payload. Free-form;
# distinguishes which TSA provider produced the witness.
network_label            = "sectigo-qualified-tsa"
